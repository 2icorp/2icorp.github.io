---
layout: none
---
[
  {% for post in site.posts %}
    {
      "title"       : "{{ post.title | escape }}",
      "url"         : "{{ post.url | relative_url }}",
      "date"        : "{{ post.date | date: '%B %d, %Y' }}",
      "categories"  : "{{ post.categories | join: ', ' }}",
      "content"     : "{{ post.content | strip_html | truncate: 400 }}"
    }{% if forloop.last == false %},{% endif %}
  {% endfor %}
]
